<% layout("layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-2">
    <h2>Create New Lisitngs</h2>
    <form action="/listings" method="post" novalidate class="needs-validation">
      <div>
        <label for="title" class="form-label">Title</label>
        <input
          type="text"
          class="form-control"
          required
          name="listing[title]"
          placeholder="Add a title..."
        />

        <div class="valid-feedback">Titles Looks Good!</div>
        <div class="invalid-feedback">Title Should be Valid !</div>
      </div>

      <div>
        <label for="description" class="form-label">Descrtiption</label>
        <textarea
          type="text"
          required
          class="form-control"
          name="listing[description]"
        ></textarea>
        <div class="invalid-feedback">Description Should be Valid !</div>
      </div>

      <div>
        <label for="image" class="form-label">Image</label>
        <input
          type="text"
          name="listing[image]"
          class="form-control"
          placeholder="Enter URL/Link..."
        />
      </div>
      <div class="row">
        <div class="col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            required
            name="listing[price]"
            class="form-control"
            placeholder="12000"
          />
          <div class="invalid-feedback">Price Should be Valid !</div>
        </div>
        <div class="col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            type="text"
            required
            name="listing[country]"
            class="form-control"
            placeholder="India"
          />
          <div class="invalid-feedback">Country name Should be Valid !</div>
        </div>
      </div>

      <div>
        <label for="location" class="form-label">Location</label>
        <input
          type="text"
          required
          name="listing[location]"
          class="form-control"
          placeholder="New Delhi"
        />
        <div class="invalid-feedback">Location Should be Valid !</div>
      </div>

      <br />
      <br />

      <button class="btn btn-dark add-btn">Add</button>
    </form>
  </div>
</div>
